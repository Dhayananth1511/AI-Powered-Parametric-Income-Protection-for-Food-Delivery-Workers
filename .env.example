# GigSecure API Key Configuration

# OpenWeatherMap API Key for live weather data (Required)
OWM_API_KEY=your_openweathermap_api_key_here

# WAQI (World Air Quality Index) API Key for real-time AQI data — Phase 3 Deep Integration
# Free key: https://aqicn.org/data-platform/token/
WAQI_API_KEY=your_waqi_api_key_here

# Razorpay API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_MODE=test

# Security
JWT_SECRET_KEY=generate_a_secure_random_string_here_like_this
TOKEN_EXPIRE_MINUTES=10080

# Environment configurations
UVICORN_LOG_LEVEL=info
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=production

# Database (PostgreSQL recommended for production — use Neon/Railway/Supabase)
# Leave blank to use local SQLite (development only)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
SKIP_SEEDING=false
