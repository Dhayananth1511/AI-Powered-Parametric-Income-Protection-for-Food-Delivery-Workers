# GigSecure Environment Configuration (Phase 2 Production-Ready)

# //this for your refrence only
# // i am using my own keys in .env file 

# ─────────────────────────────────────────────────────────────────────────────
# JWT & Security
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_here
TOKEN_EXPIRE_MINUTES=10080
BCrypt_ROUNDS=12

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
#
# ── OPTION 1: Supabase PostgreSQL (FAST — recommended for Render/production) ──
# Steps to get your URL:
#   1. Go to https://supabase.com → New Project → pick a region near India
#   2. Project Settings → Database → Connection String → URI
#   3. Copy the URI and paste below (replace [YOUR-PASSWORD])
#
# Supabase URL (Using Session Pooler for IPv4 compatibility)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── OPTION 2: Neon PostgreSQL (already set up in previous attempt) ────────────
# DATABASE_URL=postgresql://user:password@ep-odd-field.neon.tech/neondb?sslmode=require
#
# ── OPTION 3: Local SQLite (default — works with no setup) ────────────────────
# DATABASE_URL=sqlite:///./gigpulse.db
SKIP_SEEDING=false

# ─────────────────────────────────────────────────────────────────────────────
# CORS & Security
# ─────────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,https://gigsecure.app

# ─────────────────────────────────────────────────────────────────────────────
# Weather APIs
# ─────────────────────────────────────────────────────────────────────────────
OWM_API_KEY=your_owm_api_key_here
WAQI_API_KEY=your_waqi_api_key_here
IMD_API_KEY=your_imd_key_here
CPCB_API_KEY=your_cpcb_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Payment Gateway (Razorpay)
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_MODE=test

# ─────────────────────────────────────────────────────────────────────────────
# Notification Services
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_here
TWILIO_WHATSAPP_NUMBER=your_whatsapp_number_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# FREE NOTIFICATION CHANNELS
# -------------------------
# Set these to enable real-time notifications on your phone for free.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
CALLMEBOT_API_KEY=your_callmebot_api_key_here
CALLMEBOT_PHONE_NUMBER=your_callmebot_phone_number_here

# ─────────────────────────────────────────────────────────────────────────────
# IRDAI & Insurance Partner
# ─────────────────────────────────────────────────────────────────────────────
IRDAI_API_KEY=your_irdai_key_here
INSURANCE_PARTNER_ID=digit_insurance_001
INSURANCE_API_BASE=https://api.insurancepartner.com

# ─────────────────────────────────────────────────────────────────────────────
# Background Jobs
# ─────────────────────────────────────────────────────────────────────────────
AUTO_TRIGGER_INTERVAL_SECONDS=15
WEEKLY_RESET_HOUR=0
WEEKLY_RESET_MINUTE=0
DISRUPTION_CONFIRMATION_MINUTES=20

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=gigpulse.log
ENABLE_FILE_LOGGING=true
UVICORN_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Development/Production
# ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# Hugging Face AI Models
# ─────────────────────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
